# ─── Nova Agent Configuration ───

# LLM Provider: "deepseek" | "openai" | "openrouter"
LLM_PROVIDER=openrouter

# DeepSeek (direct) → https://api.deepseek.com/v1
# OpenRouter → https://openrouter.ai/api/v1
# OpenAI → https://api.openai.com/v1
LLM_BASE_URL=https://openrouter.ai/api/v1

# Your API key
LLM_API_KEY=sk-your-api-key-here

# Model name
# DeepSeek:   deepseek-chat or deepseek-reasoner
# OpenRouter: openmodel/deepseek-v4-flash
# OpenAI:     gpt-4o
LLM_MODEL=openmodel/deepseek-v4-flash

# Optional: override max tokens
# MAX_TOKENS=4096
